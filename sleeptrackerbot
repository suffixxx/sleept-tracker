    # Советы на основе данных
    advice = ""
    if data['physical_activity'] <= 3:
        advice = "\n\n💡 *Совет:* Завтра постарайся больше двигаться!"
    elif int(message.text) >= 8:
        advice = "\n\n💡 *Совет:* Ты сильно устал. Хорошо отдохни и ложись спать пораньше."
    
    await message.answer(
        f"✅ *Вечерний опрос завершен!*\n\n"
        f"💪 Активность: {data['physical_activity']}/10\n"
        f"😓 Усталость/стресс: {message.text}/10"
        f"{advice}\n\n😴 Спокойной ночи!",
        reply_markup=get_main_keyboard(),
        parse_mode="Markdown"
    )
    await state.clear()

