    stats_text = "📊 *НЕДЕЛЬНАЯ СТАТИСТИКА*\n\n"
    
    # Сон
    if stats['sleep']:
        total_sleep = sum(s['duration_hours'] for s in stats['sleep'])
        avg_sleep = total_sleep / len(stats['sleep'])
        stats_text += f"😴 *Сон:*\n"
        stats_text += f"   Средняя длительность: {avg_sleep:.1f} ч\n"
        stats_text += f"   Дней с данными: {len(stats['sleep'])}\n\n"
    else:
        stats_text += "😴 *Сон:* Нет данных\n\n"
    
    # Утренние оценки
    if stats['morning']:
        avg_quality = sum(m['sleep_quality'] for m in stats['morning']) / len(stats['morning'])
        avg_difficulty = sum(m['wake_difficulty'] for m in stats['morning']) / len(stats['morning'])
        stats_text += f"🌅 *Утро:*\n"
        stats_text += f"   Качество сна: {avg_quality:.1f}/10\n"
        stats_text += f"   Сложность подъема: {avg_difficulty:.1f}/10\n\n"
    
    # Вечерние оценки
    if stats['evening']:
        avg_activity = sum(e['physical_activity'] for e in stats['evening']) / len(stats['evening'])
        avg_fatigue = sum(e['fatigue_stress'] for e in stats['evening']) / len(stats['evening'])
        stats_text += f"🌙 *День:*\n"
        stats_text += f"   Физическая активность: {avg_activity:.1f}/10\n"
        stats_text += f"   Усталость/стресс: {avg_fatigue:.1f}/10\n\n"
    
    # Спортивные результаты
    if sports:
        stats_text += f"💪 *Спортивные результаты (последние):*\n"
        # Группируем по дисциплинам
        disciplines = {}
        for s in sports[:5]:
            if s['discipline'] not in disciplines:
                disciplines[s['discipline']] = []
            disciplines[s['discipline']].append(s)
        
        for disc, results in list(disciplines.items())[:3]:
            stats_text += f"   • {disc}: {results[0]['value']}"
            if len(results) > 1:
                diff = results[0]['value'] - results[1]['value']
                if diff > 0:
                    stats_text += f" (+{diff:.1f}) 📈"
                elif diff < 0:
                    stats_text += f" ({diff:.1f}) 📉"
            stats_text += "\n"
    
    # Общие рекомендации
    stats_text += "\n💡 *Рекомендации:*\n"
    if stats['morning'] and avg_quality < 6:
        stats_text += "• Качество сна низкое. Улучши гигиену сна\n"
    if stats['sleep'] and avg_sleep < 7:
        stats_text += "• Ты мало спишь. Старайся спать 7-8 часов\n"
    if stats['evening'] and avg_activity < 4:
        stats_text += "• Низкая физическая активность. Добавь движение в день\n"
    if not stats['morning'] and not stats['sleep']:
        stats_text += "• Начни отслеживать сон с кнопки «😴 Лечь спать»\n"
    
    await message.answer(stats_text, parse_mode="Markdown")

