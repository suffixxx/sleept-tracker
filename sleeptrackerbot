async def weekly_report():
    """Еженедельная статистика и рекомендации"""
    with closing(sqlite3.connect(DB_NAME)) as conn:
        cur = conn.execute('SELECT user_id FROM users')
        users = cur.fetchall()
    
    for user_id in users:
        try:
            uid = user_id[0]
            stats = get_weekly_stats(uid, 7)
            
            report = "📊 *ЕЖЕНЕДЕЛЬНЫЙ ОТЧЁТ*\n\n"
            
            if stats['sleep']:
                avg_sleep = sum(s['duration_hours'] for s in stats['sleep']) / len(stats['sleep'])
                report += f"😴 Средний сон: {avg_sleep:.1f} ч\n"
                
                if avg_sleep < 7:
                    report += "   ⚠️ Спи больше! 7-8 часов необходимо для восстановления\n"
                elif avg_sleep > 9:
                    report += "   💪 Хорошее восстановление!\n"
                else:
                    report += "   ✅ Отлично! Норма сна соблюдена\n"
            
            if stats['morning']:
                avg_quality = sum(m['sleep_quality'] for m in stats['morning']) / len(stats['morning'])
                report += f"🎯 Качество сна: {avg_quality:.1f}/10\n"
                
                if avg_quality < 5:
                    report += "   ⚠️ Попробуй улучшить гигиену сна\n"
            
            if stats['evening']:
                avg_fatigue = sum(e['fatigue_stress'] for e in stats['evening']) / len(stats['evening'])
                report += f"😓 Уровень стресса: {avg_fatigue:.1f}/10\n"
                
                if avg_fatigue > 7:
                    report += "   ⚠️ Высокий стресс. Найди время для отдыха\n"
            
            report += "\n🎯 *Цель на следующую неделю:*\n"
            report += "• Ложись спать до 23:00\n"
            report += "• Записывай спортивные результаты\n"
            report += "• Следи за качеством сна\n"
            
            await bot.send_message(uid, report, parse_mode="Markdown")
            
        except Exception as e:
            print(f"Ошибка отправки отчета {user_id[0]}: {e}")

# ========== НАСТРОЙКА ПЛАНИРОВЩИКА ==========
def setup_scheduler():
    # Ежедневное напоминание о сне в 21:00
    scheduler.add_job(
        send_sleep_reminders,
        trigger='cron',
        hour=21,
        minute=0,
        timezone='Asia/Yekaterinburg'
    )
    
    # Еженедельное напоминание о спортивных результатах (воскресенье в 19:00)
    scheduler.add_job(
        weekly_sports_reminder,
        trigger='cron',
        day_of_week='sun',
        hour=19,
        minute=0,
        timezone='Asia/Yekaterinburg'
    )
    
    # Еженедельный отчет (воскресенье в 20:00)
    scheduler.add_job(
        weekly_report,
        trigger='cron',
        day_of_week='sun',
        hour=20,
        minute=0,
        timezone='Asia/Yekaterinburg'
    )
    
    scheduler.start()

# ========== ЗАПУСК ==========
async def main():
    init_db()
    setup_scheduler()
    print("🤖 Бот запущен!")
    await dp.start_polling(bot)

if __name__ == '__main__':
    asyncio.run(main())
