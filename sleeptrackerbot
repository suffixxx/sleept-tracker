# ========== РАБОТА СО СНОМ (ТАЙМЕР) ==========
def start_sleep_session(user_id: int):
    with closing(sqlite3.connect(DB_NAME)) as conn:
        with conn:
            conn.execute(
                'DELETE FROM sleep_sessions WHERE user_id = ? AND sleep_end IS NULL',
                (user_id,)
            )
            conn.execute('''
                INSERT INTO sleep_sessions (user_id, sleep_start, date)
                VALUES (?, ?, ?)
            ''', (user_id, datetime.now(), datetime.now().date()))

def end_sleep_session(user_id: int):
    with closing(sqlite3.connect(DB_NAME)) as conn:
        with conn:
            cur = conn.execute('''
                SELECT id, sleep_start FROM sleep_sessions
                WHERE user_id = ? AND sleep_end IS NULL
                ORDER BY sleep_start DESC LIMIT 1
            ''', (user_id,))
            session = cur.fetchone()
            
            if session:
                session_id, start_time = session
                start_time = datetime.fromisoformat(start_time)
                end_time = datetime.now()
                duration = (end_time - start_time).total_seconds() / 3600
                
                conn.execute('''
                    UPDATE sleep_sessions
                    SET sleep_end = ?, duration_hours = ?
                    WHERE id = ?
                ''', (end_time, duration, session_id))
                
                return duration
    return None

