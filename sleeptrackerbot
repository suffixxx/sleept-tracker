# ========== БАЗА ДАННЫХ ==========
def init_db():
    with closing(sqlite3.connect(DB_NAME)) as conn:
        with conn:
            # Пользователи
            conn.execute('''
                CREATE TABLE IF NOT EXISTS users (
                    user_id INTEGER PRIMARY KEY,
                    username TEXT,
                    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                    reminder_time TEXT DEFAULT '21:00'
                )
            ''')
            
            # Сессии сна (таймер)
            conn.execute('''
                CREATE TABLE IF NOT EXISTS sleep_sessions (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    user_id INTEGER,
                    sleep_start TIMESTAMP,
                    sleep_end TIMESTAMP,
                    duration_hours REAL,
                    date DATE,
                    FOREIGN KEY(user_id) REFERENCES users(user_id)
                )
            ''')
            
            # Утренние оценки
            conn.execute('''
                CREATE TABLE IF NOT EXISTS morning_ratings (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    user_id INTEGER,
                    date DATE NOT NULL,
                    sleep_quality INTEGER,      -- 1-10
                    wake_difficulty INTEGER,    -- 1-10
                    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                    UNIQUE(user_id, date)
                )
            ''')
            
            # Вечерние оценки
            conn.execute('''
                CREATE TABLE IF NOT EXISTS evening_ratings (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    user_id INTEGER,
                    date DATE NOT NULL,
                    physical_activity INTEGER,  -- 1-10
                    fatigue_stress INTEGER,     -- 1-10
                    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                    UNIQUE(user_id, date)
                )
            ''')
            
            # Спортивные показатели (раз в неделю)
            conn.execute('''
                CREATE TABLE IF NOT EXISTS sports_results (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    user_id INTEGER,
                    week_start DATE NOT NULL,
                    discipline TEXT NOT NULL,
                    value REAL,
                    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
                )
            ''')

