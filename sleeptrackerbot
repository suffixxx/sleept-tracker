def save_sports_result(user_id: int, discipline: str, value: float):
    """Сохраняет спортивный результат за текущую неделю"""
    today = date.today()
    # Находим начало недели (понедельник)
    week_start = today - timedelta(days=today.weekday())
    
    with closing(sqlite3.connect(DB_NAME)) as conn:
        with conn:
            conn.execute('''
                INSERT INTO sports_results (user_id, week_start, discipline, value)
                VALUES (?, ?, ?, ?)
            ''', (user_id, week_start.isoformat(), discipline, value))

# ========== ПОЛУЧЕНИЕ СТАТИСТИКИ ==========
def get_weekly_stats(user_id: int, days: int = 7):
    """Получает статистику за последние N дней"""
    with closing(sqlite3.connect(DB_NAME)) as conn:
        conn.row_factory = sqlite3.Row
        
        # Утренние оценки
        morning = conn.execute('''
            SELECT sleep_quality, wake_difficulty, date
            FROM morning_ratings
            WHERE user_id = ? AND date >= date('now', ?)
            ORDER BY date DESC
        ''', (user_id, f'-{days} days')).fetchall()
        
        # Вечерние оценки
        evening = conn.execute('''
            SELECT physical_activity, fatigue_stress, date
            FROM evening_ratings
            WHERE user_id = ? AND date >= date('now', ?)
            ORDER BY date DESC
        ''', (user_id, f'-{days} days')).fetchall()
        
        # Данные о сне
        sleep = conn.execute('''
            SELECT duration_hours, date
            FROM sleep_sessions
            WHERE user_id = ? AND sleep_end IS NOT NULL
              AND date >= date('now', ?)
            ORDER BY date DESC
        ''', (user_id, f'-{days} days')).fetchall()
        
        return {
            'morning': morning,
            'evening': evening,
            'sleep': sleep,
            'days': len(set([r['date'] for r in morning]))
        }

def get_sports_history(user_id: int):
    """Получает историю спортивных результатов"""
    with closing(sqlite3.connect(DB_NAME)) as conn:
        conn.row_factory = sqlite3.Row
        cur = conn.execute('''
            SELECT discipline, value, week_start
            FROM sports_results
            WHERE user_id = ?
            ORDER BY week_start DESC, discipline
        ''', (user_id,))
        return cur.fetchall()

def get_last_two_weeks_sports(user_id: int, discipline: str):
    """Получает результаты за последние две недели для конкретной дисциплины"""
    with closing(sqlite3.connect(DB_NAME)) as conn:
        cur = conn.execute('''
            SELECT value, week_start
            FROM sports_results
            WHERE user_id = ? AND discipline = ?
            ORDER BY week_start DESC
            LIMIT 2
        ''', (user_id, discipline))
        return cur.fetchall()

